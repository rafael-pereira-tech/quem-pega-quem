# Copie para .env.local e preencha. NUNCA comite a service_role key.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica

# Cloudflare Web Analytics — token PÚBLICO do beacon (opcional).
# Onde achar: CF dashboard > Analytics & Logs > Web Analytics > seu site >
# "Manage site"/JS snippet > valor do token em data-cf-beacon.
# Em produção, setar como env var em Cloudflare Pages > Settings > Environment
# variables (Production). Sem ele, o beacon não monta (no-op).
VITE_CF_BEACON_TOKEN=
